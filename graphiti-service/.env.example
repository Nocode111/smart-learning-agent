APP_NAME=smart-learning-graphiti-service
APP_ENV=dev

GRAPHITI_URI=bolt://localhost:7687
GRAPHITI_USER=neo4j
GRAPHITI_PASSWORD=please_change_graphiti_password
GRAPHITI_GROUP_PREFIX=smart_learning
GRAPHITI_SEARCH_LIMIT=5
GRAPHITI_BUILD_INDICES_ON_START=false

DASHSCOPE_API_KEY=replace_with_your_dashscope_api_key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4
