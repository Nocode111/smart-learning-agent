APP_NAME=smart-learning-agent
APP_ENV=dev

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=smart_learning
DATABASE_URL=mysql+pymysql://root:root@localhost:3306/smart_learning?charset=utf8mb4

REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8000

JWT_SECRET=please_change_this_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

DASHSCOPE_API_KEY=替换为你的阿里云百炼API_KEY
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBEDDING_MODEL=text-embedding-v4

RAG_TOP_K=5
LLM_TEMPERATURE=0.3
ENABLE_LLM_INTENT_ROUTER=true
ENABLE_AGENT_LANGGRAPH=false
ENABLE_AGENT_MEMORY_AUTO_EXTRACT=false
AGENT_MEMORY_EXTRACT_USE_LLM=true
AGENT_MEMORY_EXTRACT_ENGINE=qwen_json
AGENT_MEMORY_EXTRACT_MAX_CANDIDATES=8

# Graphiti graph memory, served by the independent graphiti-service.
ENABLE_AGENT_GRAPHITI=false
GRAPHITI_SERVICE_URL=http://localhost:8010
GRAPHITI_HTTP_TIMEOUT_SECONDS=10
GRAPHITI_SEARCH_LIMIT=5
